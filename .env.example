# ──────────────────────────────────────────────────────────────────────────────
# Aithena — environment configuration template
#
# DO NOT use this file directly.  Run the first-run installer to generate a
# real .env with a strong JWT secret and a bootstrapped auth database:
#
#   python3 -m installer
#
# The installer writes .env (chmod 600) and creates the SQLite auth DB.
# After that, start the stack with:  docker compose up -d
#
# Re-run the installer at any time to rotate credentials or change settings.
# Existing values (JWT secret, auth DB, RabbitMQ/Redis credentials) are preserved
# unless --reset is passed.
# ──────────────────────────────────────────────────────────────────────────────

# Path to your book library on the host (set by installer --library-path)
BOOKS_PATH=/home/your-user/booklibrary

# Compatibility alias for installer consumers
BOOK_LIBRARY_PATH=/home/your-user/booklibrary

# Public origin used by the browser-facing UI and API (set by installer --origin)
PUBLIC_ORIGIN=http://localhost
CORS_ORIGINS=http://localhost

# Host directory mounted into the container for auth storage.
# The installer creates this directory and sets AUTH_DB_DIR automatically.
# Docker Compose requires this directory to exist before 'docker compose up'.
AUTH_DB_DIR=/home/your-user/.local/share/aithena/auth

# SQLite auth database path inside the container (set by the installer;
# do not change unless you also change the bind-mount target in docker-compose.yml)
AUTH_DB_PATH=/data/auth/users.db

# JWT signing secret — generated by the installer (never commit a real value)
AUTH_JWT_SECRET=generate-with-installer

# JWT lifetime accepted by src/solr-search/auth.py (e.g. 24h, 30m, 7d)
AUTH_JWT_TTL=24h

# HTTP cookie name used for browser auth sessions
AUTH_COOKIE_NAME=aithena_auth

# API key for admin endpoints (defense-in-depth).  When set, requests to
# /v1/admin/* must include this key via X-API-Key or Authorization header.
# When unset, admin endpoints are disabled (return 403).
ADMIN_API_KEY=generate-with-installer

# Bootstrap admin username created by the installer (set by installer --admin-user)
AUTH_ADMIN_USERNAME=admin

# RabbitMQ broker/admin credentials. The installer replaces these placeholders
# with a non-default username and a strong password.
RABBITMQ_USER=generate-with-installer
RABBITMQ_PASS=generate-with-installer

# Per-service RabbitMQ credentials (generated by installer; passwords must match
# definitions in src/rabbitmq/init-definitions.sh).
# lister: publish-only to 'documents' exchange (used by document-lister)
RABBITMQ_LISTER_USER=lister
RABBITMQ_LISTER_PASS=generate-with-installer
# indexer: consume from shortembeddings* queues (used by document-indexer variants)
RABBITMQ_INDEXER_USER=indexer
RABBITMQ_INDEXER_PASS=generate-with-installer
# search: publish to default exchange, monitoring tag for management health checks
RABBITMQ_SEARCH_USER=search
RABBITMQ_SEARCH_PASS=generate-with-installer
# admin: full management UI access (not used by services)
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASS=generate-with-installer

# Container build metadata — buildall.sh exports these automatically.
# Override here only when building outside of buildall.sh.
VERSION=0.8.0
GIT_COMMIT=unknown
BUILD_DATE=1970-01-01T00:00:00Z

# ── GPU Platform ──────────────────────────────────────────────────────────────
# Default: CPU-only (no changes needed)
#
# For NVIDIA GPU:
#   docker compose -f docker-compose.yml -f docker-compose.nvidia.override.yml up -d
#   (production: docker compose -f docker-compose.prod.yml -f docker-compose.nvidia.override.yml up -d)
#
# For Intel GPU:
#   docker compose -f docker-compose.yml -f docker-compose.intel.override.yml up -d --build
#   (production: docker compose -f docker-compose.prod.yml -f docker-compose.intel.override.yml up -d)
#
# The override compose files set DEVICE, BACKEND, image tags, and device
# passthrough via their `environment:` sections — no GPU-related variables
# are needed in .env.
#
# Reference (set automatically by override files, not by .env):
#   DEVICE   — cpu | cuda | xpu    (compute device for the embeddings server)
#   BACKEND  — torch | openvino    (inference backend)
#
# Optional: override the embeddings-server image tag independently
# EMBEDDINGS_VERSION=1.17.0-openvino

# ──────────────────────────────────────────────────────────────────────────────
# Solr Collection Topology
# ──────────────────────────────────────────────────────────────────────────────
# These control how the Solr "books" collection is created at first startup.
# They only take effect during initial collection creation — changing them
# after the collection exists requires deleting and recreating it.
#
# Personal deployment (single machine, ≤30K docs):
#   SOLR_NUM_SHARDS=1
#   SOLR_REPLICATION_FACTOR=1
#
# Medium deployment (single machine, 30K-100K docs):
#   SOLR_NUM_SHARDS=2
#   SOLR_REPLICATION_FACTOR=1
#
# Distributed deployment (multi-node, HA) — the default:
#   SOLR_NUM_SHARDS=1
#   SOLR_REPLICATION_FACTOR=3
#
# SOLR_NUM_SHARDS=1
# SOLR_REPLICATION_FACTOR=3
