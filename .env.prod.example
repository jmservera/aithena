# Aithena Production Environment Configuration Example
# Copy this file to .env and update with your production values

# Book Library Configuration
# Path to your book library on the host (must be absolute path)
BOOKS_PATH=/data/booklibrary

# Compatibility alias for installer consumers
BOOK_LIBRARY_PATH=/data/booklibrary

# Public Origin and CORS
# Public origin used by browsers (scheme + host, no trailing slash)
PUBLIC_ORIGIN=http://localhost

# Comma-separated CORS origins consumed by solr-search
CORS_ORIGINS=http://localhost

# Authentication Configuration
# Host directory mounted into the container for auth storage
AUTH_DB_DIR=/home/user/.local/share/aithena/auth

# SQLite auth database path inside the container
AUTH_DB_PATH=/data/auth/users.db

# JWT signing secret (REQUIRED - generate with: python3 -m installer)
# NEVER use the example value below in production!
AUTH_JWT_SECRET=CHANGE_ME_GENERATE_WITH_INSTALLER

# JWT lifetime (e.g. 24h, 7d, 30d)
AUTH_JWT_TTL=24h

# HTTP cookie name used for browser auth
AUTH_COOKIE_NAME=aithena_auth

# API key for admin endpoints (defense-in-depth).
# When set, requests to /v1/admin/* must include this key via X-API-Key header.
# When unset, admin endpoints are disabled (return 403).
# Send via X-API-Key header.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_INSTALLER

# Bootstrap admin username
AUTH_ADMIN_USERNAME=admin

# Admin dashboard configuration
# Admin password (leave empty or set via installer)
AUTH_ADMIN_PASSWORD=

# Enable/disable authentication (set to false only for testing)
AUTH_ENABLED=true

# Message Queue Configuration
# RabbitMQ broker/admin username
RABBITMQ_USER=aithena

# RabbitMQ broker/admin password (REQUIRED - generate with: python3 -m installer)
# NEVER use 'guest' in production!
RABBITMQ_PASS=CHANGE_ME_GENERATE_WITH_INSTALLER

# Cache Configuration
# Redis password (REQUIRED - generate with: python3 -m installer)
# Leave empty only for development/testing
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_INSTALLER

# Container Version Metadata
# Version number (matches VERSION file or git tag)
VERSION=1.4.0

# Git commit SHA for traceability
GIT_COMMIT=unknown

# Build timestamp (ISO 8601 format)
BUILD_DATE=unknown
