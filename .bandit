# Bandit security scanning configuration
# Baseline exceptions for legitimate patterns

# Exclude virtual environments and third-party code
exclude_dirs:
  - .venv
  - venv
  - site-packages
  - node_modules
  - __pycache__

# Skip rules for legitimate patterns
# B101: Use of assert detected (required by pytest)
# B104: Binding to 0.0.0.0 (legitimate for containerized services)
# B603: subprocess call - check for execution of untrusted input (used in e2e tests)
# B607: Starting a process with a partial executable path (used in e2e tests)
# B108: Probable insecure usage of temp file/directory (test fixtures)
# B105: Possible hardcoded password string (often false positives in test data)
# B106: Possible hardcoded password function argument (often false positives)
skips:
  - B101
  - B104
  - B603
  - B607
  - B108
  - B105
  - B106
