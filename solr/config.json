    "updateHandler":{
      "commitWithin":{
        "softCommit":true
      },
      "autoCommit":{
        "maxDocs":-1,
        "openSearcher":false,
        "maxTime":15000
      },
      "autoSoftCommit":{
        "maxTime":3000,
        "maxDocs":-1
      }
    },
    "query":{
      "useFilterForSortedQuery":false,
      "queryResultWindowSize":20,
      "queryResultMaxDocsCached":200,
      "enableLazyFieldLoading":true,
      "maxBooleanClauses":1024,
      "filterCache":{
        "autowarmCount":"0",
        "name":"filterCache",
        "size":"512",
        "initialSize":"512"
      },
      "queryResultCache":{
        "autowarmCount":"0",
        "name":"queryResultCache",
        "size":"512",
        "initialSize":"512"
