      "documentCache":{
        "autowarmCount":"0",
        "name":"documentCache",
        "size":"512",
        "initialSize":"512"
      },
      "fieldValueCache":{
        "name":"fieldValueCache",
        "size":"10000",
        "initialSize":"10"
      }
