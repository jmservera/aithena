    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "prettier": "^3.8.1",
    "typescript": "^5.0.2",
